# Production example for Render or similar hosts
# Do not commit real values. Set secrets in the Render dashboard.
PORT=3000
NODE_ENV=production
STORAGE_PROVIDER=turso
SAVE_DIR=./data
TURSO_DATABASE_URL=libsql://your-database-name-your-team.region.turso.io
TURSO_AUTH_TOKEN=replace-me-in-render-dashboard
LEGACY_SAVES_FILE=
IMPORT_LEGACY_FILE_SAVES=false
AI_PROVIDER=openrouter
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=replace-me-in-render-dashboard
OPENROUTER_MODEL=openai/gpt-4o-mini
SITE_URL=https://your-service-name.onrender.com
SITE_NAME=Echoes of Tomorrow
OLLAMA_URL=
OLLAMA_MODEL=
AI_REQUEST_TIMEOUT_MS=60000
